{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlashNote",
  "version": "0.1.0",
  "identifier": "com.flashnote.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "FlashNote",
        "width": 560,
        "height": 120,
        "minWidth": 420,
        "minHeight": 90,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": true
      },
      {
        "label": "settings",
        "title": "FlashNote 设置",
        "url": "settings.html",
        "width": 420,
        "height": 340,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
